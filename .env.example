# ==============================
# Backend selection
# ==============================
# Current supported backends:
# - DATABASE_BACKEND: postgres
# - VECTOR_STORE_BACKEND: pgvector
# Future-ready placeholders:
# - OBJECT_STORE_BACKEND: local | s3 | azure_blob
# - SKILLS_BACKEND: local | s3 | azure_blob
# - PROMPTS_BACKEND: local | s3 | azure_blob
DATABASE_BACKEND=postgres
VECTOR_STORE_BACKEND=pgvector
OBJECT_STORE_BACKEND=local
SKILLS_BACKEND=local
PROMPTS_BACKEND=local

# ==============================
# Provider selection
# ==============================
# LLM_PROVIDER: ollama | azure
LLM_PROVIDER=ollama
# EMBEDDINGS_PROVIDER: ollama | azure
EMBEDDINGS_PROVIDER=ollama
# JUDGE_PROVIDER: ollama | azure (defaults to LLM_PROVIDER if omitted)
JUDGE_PROVIDER=ollama

# ==============================
# Ollama (default)
# ==============================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=gpt-oss:20b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_JUDGE_MODEL=gpt-oss:20b
OLLAMA_TEMPERATURE=0.2
OLLAMA_NUM_PREDICT=512
JUDGE_TEMPERATURE=0.0

# ==============================
# Azure OpenAI (optional)
# ==============================
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-05-01-preview
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_JUDGE_DEPLOYMENT=
AZURE_OPENAI_EMBED_DEPLOYMENT=
AZURE_TEMPERATURE=0.2

# ==============================
# PostgreSQL / vector DB
# ==============================
PG_DSN=postgresql://raguser:ragpass@localhost:5432/ragdb
EMBEDDING_DIM=768

# ==============================
# RAG & agent limits
# ==============================
MAX_AGENT_STEPS=10
MAX_TOOL_CALLS=12
MAX_RAG_AGENT_STEPS=8
RAG_MAX_RETRIES=2
RAG_MIN_EVIDENCE_CHUNKS=2
RAG_TOPK_VECTOR=12
RAG_TOPK_BM25=12

CHUNK_SIZE=900
CHUNK_OVERLAP=150

SUPERVISOR_MAX_LOOPS=5
MAX_PARALLEL_RAG_WORKERS=4
ENABLE_PARALLEL_RAG=true
CLEAR_SCRATCHPAD_PER_TURN=true

# ==============================
# Local data and source paths
# ==============================
# DATA_DIR controls default locations for KB/uploads/skills/prompts.
DATA_DIR=./data
KB_DIR=./data/kb
UPLOADS_DIR=./data/uploads

# Future-ready source URIs (currently local/file-based ingestion only)
KB_SOURCE_URI=file://./data/kb
UPLOADS_SOURCE_URI=file://./data/uploads

# ==============================
# Skills and prompt template paths
# ==============================
SKILLS_DIR=./data/skills
PROMPTS_DIR=./data/prompts

SHARED_SKILLS_PATH=./data/skills/skills.md
GENERAL_AGENT_SKILLS_PATH=./data/skills/general_agent.md
RAG_AGENT_SKILLS_PATH=./data/skills/rag_agent.md
SUPERVISOR_AGENT_SKILLS_PATH=./data/skills/supervisor_agent.md
UTILITY_AGENT_SKILLS_PATH=./data/skills/utility_agent.md
BASIC_CHAT_SKILLS_PATH=./data/skills/basic_chat.md

# Judge/synthesis prompt templates (tokenized text files)
JUDGE_GRADING_PROMPT_PATH=./data/prompts/judge_grading.txt
JUDGE_REWRITE_PROMPT_PATH=./data/prompts/judge_rewrite.txt
GROUNDED_ANSWER_PROMPT_PATH=./data/prompts/grounded_answer.txt
RAG_SYNTHESIS_PROMPT_PATH=./data/prompts/rag_synthesis.txt
PARALLEL_RAG_SYNTHESIS_PROMPT_PATH=./data/prompts/parallel_rag_synthesis.txt

# ==============================
# OCR support (optional)
# ==============================
USE_PADDLE_OCR=true
OCR_LANGUAGE=en
OCR_USE_GPU=false
OCR_MIN_PAGE_CHARS=50

# ==============================
# Langfuse observability (optional)
# ==============================
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_DEBUG=false
