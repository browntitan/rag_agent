# ==============================
# Provider selection
# ==============================
# LLM_PROVIDER: ollama | azure
LLM_PROVIDER=ollama
# EMBEDDINGS_PROVIDER: ollama | azure
EMBEDDINGS_PROVIDER=ollama

# ==============================
# Ollama (default)
# ==============================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=gpt-oss:20b
# You need an embeddings model available in Ollama; common choice:
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TEMPERATURE=0.2
OLLAMA_NUM_PREDICT=512

# ==============================
# Azure OpenAI (optional)
# ==============================
# If you set LLM_PROVIDER=azure, you must fill these:
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-05-01-preview
AZURE_OPENAI_DEPLOYMENT=

# If you set EMBEDDINGS_PROVIDER=azure, you must also set:
AZURE_OPENAI_EMBED_DEPLOYMENT=
AZURE_TEMPERATURE=0.2

# ==============================
# RAG & agent limits
# ==============================
MAX_AGENT_STEPS=10
MAX_TOOL_CALLS=12
RAG_MAX_RETRIES=2
RAG_MIN_EVIDENCE_CHUNKS=2
RAG_TOPK_VECTOR=12
RAG_TOPK_BM25=12

CHUNK_SIZE=900
CHUNK_OVERLAP=150

# ==============================
# Storage locations (optional)
# ==============================
# KB_DIR=./data/kb
# UPLOADS_DIR=./data/uploads
# INDEXES_DIR=./data/indexes
# CHROMA_DIR=./data/indexes/chroma
# BM25_PATH=./data/indexes/bm25.pkl
# DOCSTORE_PATH=./data/indexes/docstore.json

# ==============================
# Langfuse observability (optional)
# ==============================
# Run Langfuse locally (docker) and set these to enable tracing.
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_DEBUG=false
