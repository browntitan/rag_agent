# Standalone demo_notebook config
# This file is intentionally independent from the production app .env.
# Docker compose for notebook runtime: ./docker-compose.yml

# Provider selection: azure | ollama | vllm
NOTEBOOK_PROVIDER=ollama

# Shared runtime
NOTEBOOK_PG_DSN=postgresql://raguser:ragpass@localhost:5432/ragdb
NOTEBOOK_KB_DIR=../data/kb
# Ollama nomic-embed-text is 768. Azure ada-002 is 1536.
NOTEBOOK_EMBEDDING_DIM=768
NOTEBOOK_CHUNK_SIZE=900
NOTEBOOK_CHUNK_OVERLAP=120
NOTEBOOK_RAG_TOP_K_VECTOR=8
NOTEBOOK_RAG_TOP_K_KEYWORD=8
NOTEBOOK_MAX_AGENT_STEPS=8
NOTEBOOK_MAX_TOOL_CALLS=10
NOTEBOOK_TEMPERATURE=0.2
NOTEBOOK_JUDGE_TEMPERATURE=0.0

# Skills showcase controls (standalone notebook only)
NOTEBOOK_SKILLS_ENABLED=true
NOTEBOOK_SKILLS_DIR=./skills
NOTEBOOK_SKILLS_SHOWCASE_MODE=false

# Azure OpenAI
NOTEBOOK_AZURE_API_KEY=
NOTEBOOK_AZURE_ENDPOINT=https://YOUR-RESOURCE.openai.azure.us/
NOTEBOOK_AZURE_API_VERSION=2024-05-01-preview
NOTEBOOK_AZURE_CHAT_DEPLOYMENT=gpt-4o
NOTEBOOK_AZURE_JUDGE_DEPLOYMENT=gpt-4o
NOTEBOOK_AZURE_EMBED_DEPLOYMENT=text-embedding-ada-002

# Ollama
NOTEBOOK_OLLAMA_BASE_URL=http://localhost:11434
NOTEBOOK_OLLAMA_CHAT_MODEL=qwen3:8b
NOTEBOOK_OLLAMA_JUDGE_MODEL=qwen3:8b
NOTEBOOK_OLLAMA_EMBED_MODEL=nomic-embed-text
NOTEBOOK_OLLAMA_NUM_PREDICT=1024

# vLLM (OpenAI-compatible)
NOTEBOOK_VLLM_BASE_URL=http://localhost:8001/v1
NOTEBOOK_VLLM_API_KEY=not-required
NOTEBOOK_VLLM_CHAT_MODEL=meta-llama/Llama-3.1-8B-Instruct
NOTEBOOK_VLLM_JUDGE_MODEL=meta-llama/Llama-3.1-8B-Instruct
NOTEBOOK_VLLM_EMBED_MODEL=
# true -> use OpenAI-compatible embeddings endpoint exposed by vLLM
# false -> local deterministic fallback embeddings
NOTEBOOK_VLLM_USE_OPENAI_EMBEDDINGS=false

# Optional docker-compose overrides (demo_notebook/docker-compose.yml)
NOTEBOOK_DOCKER_PG_DB=ragdb
NOTEBOOK_DOCKER_PG_USER=raguser
NOTEBOOK_DOCKER_PG_PASSWORD=ragpass
NOTEBOOK_DOCKER_PG_PORT=5432
NOTEBOOK_DOCKER_OLLAMA_PORT=11434
