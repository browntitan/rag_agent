# ==============================
# Backend selection
# ==============================
DATABASE_BACKEND=postgres
VECTOR_STORE_BACKEND=pgvector
OBJECT_STORE_BACKEND=local
SKILLS_BACKEND=local
PROMPTS_BACKEND=local

# ==============================
# Provider selection
# ==============================
# Single-provider setups usually set all three roles to the same provider.
# Mixed mode is supported by splitting chat/judge/embeddings explicitly.
LLM_PROVIDER=ollama
EMBEDDINGS_PROVIDER=ollama
JUDGE_PROVIDER=ollama

# ==============================
# Ollama
# ==============================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=gpt-oss:20b
OLLAMA_EMBED_MODEL=nomic-embed-text:latest
OLLAMA_JUDGE_MODEL=gpt-oss:20b
OLLAMA_BOOTSTRAP_MODELS=gpt-oss:20b,nomic-embed-text:latest
OLLAMA_TEMPERATURE=0.2
OLLAMA_NUM_PREDICT=2048
DEMO_OLLAMA_NUM_PREDICT=2048

# Optional per-agent runtime model overrides
AGENT_BASIC_CHAT_MODEL=gpt-oss:20b
AGENT_BASIC_JUDGE_MODEL=gpt-oss:20b
AGENT_GENERAL_CHAT_MODEL=gpt-oss:20b
AGENT_GENERAL_JUDGE_MODEL=gpt-oss:20b
AGENT_COORDINATOR_CHAT_MODEL=gpt-oss:20b
AGENT_COORDINATOR_JUDGE_MODEL=gpt-oss:20b
AGENT_UTILITY_CHAT_MODEL=gpt-oss:20b
AGENT_UTILITY_JUDGE_MODEL=gpt-oss:20b
AGENT_DATA_ANALYST_CHAT_MODEL=gpt-oss:20b
AGENT_DATA_ANALYST_JUDGE_MODEL=gpt-oss:20b
AGENT_RAG_WORKER_CHAT_MODEL=gpt-oss:20b
AGENT_RAG_WORKER_JUDGE_MODEL=gpt-oss:20b
AGENT_PLANNER_CHAT_MODEL=gpt-oss:20b
AGENT_PLANNER_JUDGE_MODEL=gpt-oss:20b
AGENT_FINALIZER_CHAT_MODEL=gpt-oss:20b
AGENT_FINALIZER_JUDGE_MODEL=gpt-oss:20b
AGENT_VERIFIER_CHAT_MODEL=gpt-oss:20b
AGENT_VERIFIER_JUDGE_MODEL=gpt-oss:20b
AGENT_MEMORY_MAINTAINER_CHAT_MODEL=gpt-oss:20b
AGENT_MEMORY_MAINTAINER_JUDGE_MODEL=gpt-oss:20b


# ==============================
# Azure OpenAI
# ==============================
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-05-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_JUDGE_DEPLOYMENT=
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=
AZURE_TEMPERATURE=0.2
JUDGE_TEMPERATURE=0.0

# ==============================
# HTTP / TLS
# ==============================
HTTP2_ENABLED=true
SSL_VERIFY=true
SSL_CERT_FILE=
TIKTOKEN_ENABLED=true
TIKTOKEN_CACHE_DIR=./data/cache/tiktoken

# ==============================
# NVIDIA OpenAI-compatible
# ==============================
NVIDIA_OPENAI_ENDPOINT=
NVIDIA_API_TOKEN=
NVIDIA_CHAT_MODEL=
NVIDIA_JUDGE_MODEL=
NVIDIA_TEMPERATURE=0.0

# ==============================
# PostgreSQL / vector DB
# ==============================
PG_DSN=postgresql://raguser:ragpass@localhost:5432/ragdb
EMBEDDING_DIM=768
RAG_DB_NAME=ragdb
RAG_DB_USER=raguser
RAG_DB_PASSWORD=ragpass
RAG_DB_PORT=5432

# ==============================
# Runtime limits
# ==============================
MAX_AGENT_STEPS=10
MAX_TOOL_CALLS=12
MAX_RAG_AGENT_STEPS=8
DATA_ANALYST_MAX_STEPS=10
RAG_MAX_RETRIES=2
RAG_MIN_EVIDENCE_CHUNKS=2
RAG_TOPK_VECTOR=12
RAG_TOPK_BM25=12
CHUNK_SIZE=900
CHUNK_OVERLAP=150

# ==============================
# Runtime planning / execution
# ==============================
PLANNER_MAX_TASKS=8
CLEAR_SCRATCHPAD_PER_TURN=true

# ==============================
# Local data and collections
# ==============================
DATA_DIR=./data
KB_DIR=./data/kb
KB_EXTRA_DIRS=./docs
UPLOADS_DIR=./data/uploads
KB_SOURCE_URI=file://./data/kb
UPLOADS_SOURCE_URI=file://./data/uploads
DEFAULT_COLLECTION_ID=default
SKILL_PACKS_DIR=./data/skill_packs

# ==============================
# Skills and prompts
# ==============================
SKILLS_DIR=./data/skills
PROMPTS_DIR=./data/prompts
SHARED_SKILLS_PATH=./data/skills/skills.md
GENERAL_AGENT_SKILLS_PATH=./data/skills/general_agent.md
RAG_AGENT_SKILLS_PATH=./data/skills/rag_agent.md
SUPERVISOR_AGENT_SKILLS_PATH=./data/skills/supervisor_agent.md
UTILITY_AGENT_SKILLS_PATH=./data/skills/utility_agent.md
BASIC_CHAT_SKILLS_PATH=./data/skills/basic_chat.md
PLANNER_AGENT_SKILLS_PATH=./data/skills/planner_agent.md
FINALIZER_AGENT_SKILLS_PATH=./data/skills/finalizer_agent.md
JUDGE_GRADING_PROMPT_PATH=./data/prompts/judge_grading.txt
JUDGE_REWRITE_PROMPT_PATH=./data/prompts/judge_rewrite.txt
GROUNDED_ANSWER_PROMPT_PATH=./data/prompts/grounded_answer.txt
RAG_SYNTHESIS_PROMPT_PATH=./data/prompts/rag_synthesis.txt

# ==============================
# Demo KB and skill retrieval
# ==============================
SEED_DEMO_KB_ON_STARTUP=true
SKILL_SEARCH_TOP_K=4
SKILL_CONTEXT_MAX_CHARS=4000

# ==============================
# OCR
# ==============================
USE_PADDLE_OCR=true
OCR_LANGUAGE=en
OCR_USE_GPU=false
OCR_MIN_PAGE_CHARS=50

# ==============================
# Context defaults
# ==============================
DEFAULT_TENANT_ID=local-dev
DEFAULT_USER_ID=local-cli
DEFAULT_CONVERSATION_ID=local-session

# ==============================
# Gateway
# ==============================
GATEWAY_MODEL_ID=enterprise-agent

# ==============================
# Sandbox / data analyst
# ==============================
SANDBOX_DOCKER_IMAGE=python:3.12-slim
SANDBOX_TIMEOUT_SECONDS=60
SANDBOX_MEMORY_LIMIT=512m
WORKSPACE_DIR=./data/workspaces
WORKSPACE_SESSION_TTL_HOURS=24

# ==============================
# Router and web search
# ==============================
LLM_ROUTER_ENABLED=true
LLM_ROUTER_CONFIDENCE_THRESHOLD=0.7
WEB_SEARCH_ENABLED=false
TAVILY_API_KEY=

# ==============================
# Langfuse
# ==============================
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_DEBUG=false
